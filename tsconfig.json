{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@plangs/schema": ["packages/schema/src/index.ts"],
      "@plangs/graph": ["packages/graph/src/index.ts"]
    }
  },
  "include": ["packages/schema/src", "packages/graph/src", "packages/pipeline/src", "apps/site/src", "scripts"],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "packages/ai",
    "packages/auxiliar",
    "packages/definitions",
    "packages/frontend",
    "packages/functions",
    "packages/graphgen",
    "packages/languist",
    "packages/plangs",
    "packages/server",
    "archived"
  ]
}

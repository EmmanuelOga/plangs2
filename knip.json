{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.mjs"],
      "project": ["scripts/**/*.mjs"]
    },
    "packages/schema": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/graph": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/pipeline": {
      "entry": ["src/**/*.test.ts", "test/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/site": {
      "entry": ["src/pages/**/*.{astro,ts}", "scripts/*.mjs", "test/**/*.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.{ts,tsx,astro}"]
    }
  },
  "ignoreDependencies": ["tailwindcss"]
}

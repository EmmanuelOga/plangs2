{
  "name": "@plangs/project",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "biome check .",
    "fmt": "biome check --write .",
    "data:migrate": "node scripts/migrate-definitions.mjs",
    "data:fmt": "pnpm -F @plangs/data fmt"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "yaml": "catalog:"
  }
}

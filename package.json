{
  "name": "@plangs/project",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run --project=unit",
    "test:watch": "vitest",
    "check": "biome check . && knip",
    "fmt": "biome check --write .",
    "url-parity": "node scripts/url-parity.mjs",
    "data:fmt": "pnpm -F @plangs/data fmt",
    "pipeline": "pnpm -F @plangs/pipeline pipeline",
    "test:browser": "vitest run --project=browser",
    "test:all": "vitest run",
    "knip": "knip"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "knip": "^6.26.0",
    "playwright": "catalog:",
    "sirv": "^3.0.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}

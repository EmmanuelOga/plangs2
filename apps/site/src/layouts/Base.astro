---
import { Font } from "astro:assets";
import PromptMenu from "../islands/PromptMenu.tsx";
import ThemeToggle from "../islands/ThemeToggle.tsx";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  /** Canonical markdown-twin URL for LLM consumers (PLAN §7). */
  markdownHref?: string;
  /** OpenGraph image path (defaults to the site card). */
  image?: string;
  /** What this page is about, used by the prompt menu (PLAN §7.5). */
  subject?: string;
}
const { title, description, markdownHref, image = "/images/plangs-1200x630.png", subject } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://plangs.page");
const ogImage = new URL(image, Astro.site ?? "https://plangs.page");
const nav = [
  ["/plangs", "Languages"],
  ["/tools", "Tools"],
  ["/libraries", "Libraries"],
  ["/apps", "Apps"],
  ["/paradigms", "Paradigms"],
  ["/tags", "Tags"],
  ["/blog", "Blog"],
  ["/about", "About"],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical.href} />
    {markdownHref && <link rel="alternate" type="text/markdown" href={markdownHref} />}
    <link rel="icon" href="/favicon.svg" />
    {/* OpenGraph / Twitter (PLAN §11: preserve SEO metadata). */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="plangs!" />
    <meta property="og:title" content={title} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    {description && <meta property="og:description" content={description} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage.href} />
    <Font cssVariable="--font-nunito" preload />
    <Font cssVariable="--font-rubik" />
    {/* Set theme before paint to avoid a flash (PLAN §6.3). */}
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem("theme");
          const dark = stored ? stored === "dark" : matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.classList.toggle("dark", dark);
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="min-h-dvh">
    <header class="flex items-center gap-4 border-b border-primary/30 px-4 py-3">
      <a href="/" class="brand text-xl font-bold no-underline">plangs!</a>
      <nav class="flex flex-1 flex-wrap gap-3 text-sm">
        {nav.map(([href, label]) => <a href={href} class="no-underline hover:underline">{label}</a>)}
      </nav>
      <PromptMenu client:load canonical={canonical.href} markdownHref={markdownHref} subject={subject ?? title.replace(/ — plangs!$/, "")} />
      <ThemeToggle client:load />
    </header>
    <main id="id-mainContent" class="px-4 py-6">
      <slot />
    </main>
  </body>
</html>

---
import { type NodeDetail, urlKind } from "../lib/view";

interface Props {
  detail: NodeDetail;
}
const { detail } = Astro.props;
const mdHref = detail.kind === "plang" ? `/${detail.slug}.md` : `/${urlKind(detail.kind)}/${detail.slug}.md`;
const itemType =
  detail.kind === "plang"
    ? "https://schema.org/ComputerLanguage"
    : detail.kind === "app" || detail.kind === "tool" || detail.kind === "library"
      ? "https://schema.org/SoftwareApplication"
      : "https://schema.org/Thing";
// `data` is typed per kind (PLAN §4a), so shared fields read straight off it.
// `extGithubPath` exists only on the GitHub-backed kinds, so it needs an `in`
// check — which narrows the union rather than re-probing an untyped bag.
const d = detail.data;
const desc = d.description;
const home = d.extHomeURL;
const github = "extGithubPath" in d ? d.extGithubPath : undefined;
const wikipedia = d.extWikipediaPath;
const created = d.created;

// GitHub edit deep-link for the node's YAML — this replaces the v2 /edit editor
// and its PR worker (PLAN Decision D3). Note the path uses the real node kind
// (`typeSystem`), not the lower-cased URL segment.
const REPO = "https://github.com/EmmanuelOga/plangs2";
const editHref = `${REPO}/edit/main/packages/data/nodes/${detail.kind}/${detail.slug}.yaml`;
---

{/* schema.org microdata — plangs are ComputerLanguage, everything else SoftwareApplication-ish (PLAN §8). */}
<article class="mx-auto max-w-4xl" itemscope itemtype={itemType}>
  <header class="mb-6 flex items-center gap-4">
    {detail.thumb && <img src={detail.thumb} alt="" itemprop="image" width="72" height="72" class="size-18 object-contain" />}
    <div>
      <p class="text-xs uppercase tracking-wide opacity-60">{detail.kindLabel}</p>
      <h1 class="text-3xl" itemprop="name">{detail.name}</h1>
      {created && <p class="text-sm opacity-70">Appeared <span itemprop="dateCreated">{created}</span></p>}
    </div>
  </header>

  {desc && <p class="mb-6 max-w-prose leading-relaxed" itemprop="description">{desc}</p>}

  <div class="mb-6 flex flex-wrap gap-3 text-sm">
    {home && <a href={home} class="underline">Homepage</a>}
    {github && <a href={`https://github.com/${github}`} class="underline">GitHub</a>}
    {wikipedia && <a href={`https://en.wikipedia.org/wiki/${wikipedia}`} class="underline">Wikipedia</a>}
    <a href={mdHref} class="underline">Markdown</a>
    <a href={editHref} class="underline opacity-70">Edit</a>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    {
      detail.relations.map(group => (
        <section>
          <h2 class="mb-2 text-lg">{group.label}</h2>
          <ul class="flex flex-wrap gap-2">
            {group.items.map(item => (
              <li>
                <a href={item.href} class="rounded border border-primary/30 px-2 py-0.5 text-sm no-underline hover:border-primary">
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</article>

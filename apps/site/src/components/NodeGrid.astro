---
import { type NodeKind, parseKey } from "@plangs/schema";
import FacetsPanel, { type FacetDimension } from "../islands/FacetsPanel.tsx";
import { getGraph } from "../lib/graph";
import { facetKindsFor, hrefForKey, nodeCards, nodeName } from "../lib/view";

interface Props {
  kind: NodeKind;
  /** Plural noun for the result count, e.g. "languages". */
  noun: string;
}
const { kind, noun } = Astro.props;

const graph = getGraph();
const cards = nodeCards(graph, kind);
const slug = (key: string) => parseKey(key)?.slug ?? key;

const dimensions: FacetDimension[] = facetKindsFor(kind)
  .map(d => {
    const counts = new Map<string, number>();
    const names = new Map<string, string>();
    for (const card of cards) {
      for (const key of card.facets[d.dim] ?? []) {
        const s = slug(key);
        counts.set(s, (counts.get(s) ?? 0) + 1);
        if (!names.has(s)) names.set(s, nodeName(graph, key));
      }
    }
    const options = [...counts.entries()]
      .map(([value, count]) => ({ value, count, label: names.get(value) ?? value }))
      .sort((a, b) => b.count - a.count || a.label.localeCompare(b.label));
    return { dim: d.dim, label: d.label, options };
  })
  .filter(d => d.options.length > 1);

const dataAttr = (keys: string[] = []) => keys.map(slug).join(" ");
---

<div class="@container grid gap-6 @3xl:grid-cols-[18rem_1fr]">
  {/* Facets: sidebar on wide containers, bottom-sheet drawer on phones (PLAN §8). */}
  <FacetsPanel client:load dimensions={dimensions} noun={noun} total={cards.length} />

  <section>
    <p class="mb-3 text-sm opacity-70" aria-live="polite">
      <span data-result-count>{cards.length}</span>{` ${noun}`}
    </p>
    <ul class="grid grid-cols-[repeat(auto-fill,minmax(9rem,1fr))] gap-3">
      {
        cards.map(card => (
          <li
            data-grid-item
            data-key={card.key}
            data-paradigms={dataAttr(card.facets.paradigms)}
            data-tags={dataAttr(card.facets.tags)}
            data-platforms={dataAttr(card.facets.platforms)}
            data-typesystems={dataAttr(card.facets.typeSystems)}
            data-licenses={dataAttr(card.facets.licenses)}>
            <a
              href={hrefForKey(card.key)}
              class="flex h-full flex-col items-center gap-2 rounded-lg border border-primary/20 bg-thumbnails p-3 text-center no-underline transition hover:border-primary focus-visible:outline-2 focus-visible:outline-primary">
              {card.thumb ? (
                <img src={card.thumb} alt="" width="64" height="64" loading="lazy" class="size-16 object-contain" />
              ) : (
                <span aria-hidden="true" class="flex size-16 items-center justify-center rounded bg-primary/10 text-2xl text-primary">
                  {card.name.slice(0, 1)}
                </span>
              )}
              <span class="text-sm font-medium text-foreground">{card.name}</span>
              {card.ranking ? <span class="text-xs opacity-60">#{card.ranking}</span> : null}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</div>

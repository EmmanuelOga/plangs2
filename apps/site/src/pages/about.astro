---
import { getEntry, render } from "astro:content";
import Base from "../layouts/Base.astro";

const entry = await getEntry("pages", "about");
if (!entry) throw new Error("Missing about content entry");
const { Content } = await render(entry);
---

<Base title="About — plangs!" description="About the plangs! programming languages database.">
  <article class="mx-auto max-w-prose">
    <h1 class="mb-6 text-3xl">{entry.data.title}</h1>
    <div class="flex flex-col gap-4 leading-relaxed [&_h2]:mt-6 [&_h2]:text-2xl [&_li]:ml-6 [&_li]:list-disc">
      <Content />
    </div>
    <p class="mt-8 text-sm opacity-70">
      The data lives as one YAML file per node in the repository. Every page has a machine-readable markdown twin (add
      <code>.md</code> to any URL) and the site is described for agents at <a href="/llms.txt">/llms.txt</a>.
    </p>
  </article>
</Base>

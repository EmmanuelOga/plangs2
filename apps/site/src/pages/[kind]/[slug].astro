---
import { nodesByKind } from "@plangs/graph";
import { ALL_KINDS, parseKey } from "@plangs/schema";
import NodeDetail from "../../components/NodeDetail.astro";
import Base from "../../layouts/Base.astro";
import { getGraph } from "../../lib/graph";
import { urlKind } from "../../lib/url";
import { nodeDetail } from "../../lib/view";

export function getStaticPaths() {
  const graph = getGraph();
  const paths = [];
  for (const kind of ALL_KINDS) {
    if (kind === "plang" || kind === "post") continue; // plangs live at /{slug}; posts are content
    for (const key of nodesByKind(graph, kind)) {
      const slug = parseKey(key)?.slug;
      if (slug) paths.push({ params: { kind: urlKind(kind), slug }, props: { key } });
    }
  }
  return paths;
}

const { key } = Astro.props;
const detail = nodeDetail(getGraph(), key as string);
if (!detail) return Astro.rewrite("/404");
const description = detail.data.shortDesc;
---

<Base title={`${detail.name} — plangs!`} description={description} markdownHref={`/${urlKind(detail.kind)}/${detail.slug}.md`}>
  <NodeDetail detail={detail} />
</Base>
